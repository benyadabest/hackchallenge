# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit your actual secrets.

# ---- Postgres connection string ----
# Local Postgres example:
#   DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/nanobanana
# Hosted (Neon / Supabase / Railway / Render) — usually requires sslmode=require:
#   DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# ---- xAI API key ----
# Used by xai.js to call /v1/images/edits. Get one at https://x.ai/api
XAI_API_KEY=

# ---- Server port ----
# Defaults to 3000. Set to 3001 (or anything free) to avoid clashing
# with the Next.js app currently bound to :3000.
PORT=3001
